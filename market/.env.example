# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Solana cluster: "devnet" while building, "mainnet-beta" for production
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# Deployed escrow program (devnet)
NEXT_PUBLIC_ESCROW_PROGRAM_ID=CdFkaRcdsAmkFPLYJfonUuPHxGuYb2BSyhJgnKrQkCqv

# GitHub oracle (server-side only — a fine-grained token with public repo read is enough).
# Leave empty to use unauthenticated GitHub API (lower rate limit).
GITHUB_TOKEN=
